# Copy to `Vendor/.env` OR place beside `Vendor/` as `.env`.
#
# Database table prefix: keep `ci_` so `Config\CiTables` logical names (e.g. products, users)
# resolve to physical tables `ci_products`, `ci_users`, `ci_migration`, etc.
# If you set this empty, raw DDL and Forge would disagree — leave as ci_ unless you refactor prefixes.
# database.default.DBPrefix = ci_
#
# Gmail (Google Workspace / gmail.com) SMTP KB summary:
#   Server: smtp.gmail.com
#   Authentication: required (full Gmail address + App Password)
#   TLS/STARTTLS: port 587 — use email.SMTPCrypto = tls (CodeIgniter STARTTLS)
#   SSL (implicit): port 465 — use email.SMTPCrypto = ssl if you choose this port
# App passwords: Google Account → Security → 2-Step Verification → App passwords.

email.protocol = smtp
email.SMTPHost = smtp.gmail.com
email.SMTPUser = you@gmail.com
email.SMTPPass =
email.SMTPPort = 587
email.SMTPCrypto = tls
email.fromEmail = you@gmail.com
email.fromName = Product Store

# Laravel-style aliases (same behaviour):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=you@gmail.com
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=you@gmail.com

# --- Optional: PHP mail() / CI protocol "sendmail" (XAMPP sendmail.exe) ---
# Same path as php.ini sendmail_path (executable only; CI adds -oi … -t). Sets ini sendmail_path at runtime.
# email.mailPath = B:\AppData\PortableApps\XamppPortable\App\Xampp\sendmail\sendmail.exe
# email.protocol = sendmail
# Or reuse the key name from FrameWork.Links.Default.txt:
# CURRENT_MAIL_EXE_PATH = B:\AppData\PortableApps\XamppPortable\App\Xampp\sendmail\sendmail.exe

# Optional: after the first admin exists, allow more via Member/Admin/Register by setting a shared secret:
# admin.registerKey = your-long-random-string
